# Server
PORT=3000
NODE_ENV=development

# Database (MySQL 8+)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=social_worker_ai

# JWT
JWT_SECRET=
JWT_EXPIRY=24h

# Encryption (AES-256-CBC)
ENCRYPTION_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Mistral (Profe agent + Kiddo chatbot via Conversations API)
MISTRAL_API_KEY=
MISTRAL_AGENT_ID=
MISTRAL_KIDDO_AGENT_ID=

# Demo mode (prototype only — allows sessions without auth)
# WARNING: Set to false for production deployments
DEMO_MODE=false
DEMO_USER_ID=1

# Twilio (SMS + voice alerts — optional, for crisis notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MONITOR_PHONE=

# SendGrid (email alerts — optional, for crisis notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_MONITOR_EMAIL=
